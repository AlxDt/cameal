@page "/grocery-list"
@using Cameal.Client.Web.Services
@using Cameal.Client.Web.Models
@using Microsoft.JSInterop
@inject IRecipeApiClient RecipeApi
@inject IExcelExportService ExcelExportService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Grocery List</PageTitle>

<h1>Grocery List Generator</h1>
<p>Select recipes to generate a consolidated grocery list.</p>

@if (recipes == null)
{
    <p><em>Loading recipes...</em></p>
}
else if (!recipes.Any())
{
    <div class="alert alert-info">
        <p>No recipes available. <a href="/recipes">Create some recipes first</a> to generate a grocery list.</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Select Recipes</h5>
            <div class="row">
                @foreach (var recipe in recipes)
                {
                    <div class="col-md-6 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" 
                                   type="checkbox" 
                                   id="recipe-@recipe.Id" 
                                   @onchange="(e) => ToggleRecipe(recipe.Id, (bool)e.Value!)" />
                            <label class="form-check-label" for="recipe-@recipe.Id">
                                @recipe.Name (@recipe.Ingredients.Count ingredients)
                            </label>
                        </div>
                    </div>
                }
            </div>
            <button class="btn btn-primary mt-3" 
                    @onclick="GenerateGroceryList" 
                    disabled="@(!selectedRecipeIds.Any())">
                Generate Grocery List
            </button>
        </div>
    </div>

    @if (groceryList != null && groceryList.Any())
    {
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Your Grocery List</h5>
                    <button class="btn btn-success" @onclick="ExportToExcel">
                        <span>?? Export to Excel</span>
                    </button>
                </div>
                <ul class="list-group">
                    @foreach (var item in groceryList.OrderBy(i => i.Name))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@item.Name</span>
                            <span class="badge bg-primary rounded-pill">@item.TotalQuantity @item.Unit</span>
                        </li>
                    }
                </ul>
                <div class="mt-3">
                    <p class="text-muted">Total items: @groceryList.Count()</p>
                </div>
            </div>
        </div>
    }
    else if (groceryList != null && !groceryList.Any())
    {
        <div class="alert alert-warning">
            Selected recipes have no ingredients to display.
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
}

@code {
    private List<RecipeDto>? recipes;
    private List<GroceryListItemDto>? groceryList;
    private HashSet<Guid> selectedRecipeIds = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        try
        {
            var result = await RecipeApi.GetAllRecipesAsync();
            recipes = result.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load recipes: {ex.Message}";
        }
    }

    private void ToggleRecipe(Guid recipeId, bool isSelected)
    {
        if (isSelected)
        {
            selectedRecipeIds.Add(recipeId);
        }
        else
        {
            selectedRecipeIds.Remove(recipeId);
        }
    }

    private async Task GenerateGroceryList()
    {
        errorMessage = null;
        groceryList = null;

        if (!selectedRecipeIds.Any())
        {
            errorMessage = "Please select at least one recipe";
            return;
        }

        try
        {
            var request = new GenerateGroceryListRequest(selectedRecipeIds.ToList());
            var result = await RecipeApi.GenerateGroceryListAsync(request);
            groceryList = result.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to generate grocery list: {ex.Message}";
        }
    }

    private async Task ExportToExcel()
    {
        if (groceryList == null || !groceryList.Any())
        {
            return;
        }

        try
        {
            var excelData = ExcelExportService.ExportGroceryListToExcel(groceryList);
            var fileName = $"GroceryList_{DateTime.Now:yyyy-MM-dd_HHmmss}.xlsx";
            
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", Convert.ToBase64String(excelData));
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export grocery list: {ex.Message}";
        }
    }
}


