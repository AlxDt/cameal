@page "/grocery-list"
@using Cameal.Client.Web.Services
@using Cameal.Client.Web.Models
@using Microsoft.JSInterop
@using System.Text
@inject IRecipeApiClient RecipeApi
@inject IExcelExportService ExcelExportService
@inject ITextExportService TextExportService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Grocery List</PageTitle>

<h1>Grocery List Generator</h1>
<p>Select recipes to generate a consolidated grocery list.</p>

@if (recipes == null)
{
    <p><em>Loading recipes...</em></p>
}
else if (!recipes.Any())
{
    <div class="alert alert-info">
        <p>No recipes available. <a href="/recipes">Create some recipes first</a> to generate a grocery list.</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">Select Recipes</h5>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="SelectAllRecipes">
                        Select All
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DeselectAllRecipes" disabled="@(!selectedRecipeIds.Any())">
                        Deselect All
                    </button>
                </div>
            </div>
            <div class="row">
                @foreach (var recipe in recipes)
                {
                    <div class="col-md-6 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" 
                                   type="checkbox" 
                                   id="recipe-@recipe.Id"
                                   checked="@selectedRecipeIds.Contains(recipe.Id)"
                                   @onchange="(e) => ToggleRecipe(recipe.Id, (bool)e.Value!)" />
                            <label class="form-check-label" for="recipe-@recipe.Id">
                                @recipe.Name (@recipe.Ingredients.Count ingredients)
                            </label>
                        </div>
                    </div>
                }
            </div>
            <button class="btn btn-primary mt-3" 
                    @onclick="GenerateGroceryList" 
                    disabled="@(!selectedRecipeIds.Any())">
                Generate Grocery List
            </button>
        </div>
    </div>

    @if (groceryList != null && groceryList.Any())
    {
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Your Grocery List</h5>
                    <div>
                        <button class="btn btn-success me-2" @onclick="ExportToExcel">
                            Export to Excel
                        </button>
                        <button class="btn btn-info" @onclick="ExportToSamsungNotes">
                            Export to Samsung Notes
                        </button>
                    </div>
                </div>
                <ul class="list-group">
                    @foreach (var item in groceryList.OrderBy(i => i.Name))
                    {
                        var itemKey = $"{item.Name}_{item.Unit}";
                        var isChecked = checkedItems.Contains(itemKey);
                        
                        <li class="list-group-item">
                            <div class="d-flex align-items-center">
                                <div class="form-check me-3">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           id="@itemKey" 
                                           checked="@isChecked"
                                           @onchange="(e) => ToggleCheckItem(itemKey, (bool)e.Value!)" />
                                </div>
                                <div class="flex-grow-1" style="@(isChecked ? "text-decoration: line-through; opacity: 0.6;" : "")">
                                    <strong>@item.Name</strong>
                                </div>
                                <div class="ms-3">
                                    <span class="badge bg-primary rounded-pill">@item.TotalQuantity @item.Unit</span>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
                <div class="mt-3 d-flex justify-content-between align-items-center">
                    <p class="text-muted mb-0">
                        Total items: @groceryList.Count() | 
                        Checked: @checkedItems.Count | 
                        Remaining: @(groceryList.Count() - checkedItems.Count)
                    </p>
                    @if (checkedItems.Any())
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearCheckedItems">
                            Clear Checked Items
                        </button>
                    }
                </div>
            </div>
        </div>
    }
    else if (groceryList != null && !groceryList.Any())
    {
        <div class="alert alert-warning">
            Selected recipes have no ingredients to display.
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
}

@code {
private List<RecipeDto>? recipes;
private List<GroceryListItemDto>? groceryList;
private HashSet<Guid> selectedRecipeIds = new();
private HashSet<string> checkedItems = new();
private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        try
        {
            var result = await RecipeApi.GetAllRecipesAsync();
            recipes = result.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load recipes: {ex.Message}";
        }
    }

    private void ToggleRecipe(Guid recipeId, bool isSelected)
    {
        if (isSelected)
        {
            selectedRecipeIds.Add(recipeId);
        }
        else
        {
            selectedRecipeIds.Remove(recipeId);
        }
    }

    private void SelectAllRecipes()
    {
        if (recipes != null)
        {
            selectedRecipeIds = recipes.Select(r => r.Id).ToHashSet();
        }
    }

    private void DeselectAllRecipes()
    {
        selectedRecipeIds.Clear();
    }

    private async Task GenerateGroceryList()
    {
        errorMessage = null;
        groceryList = null;
        checkedItems.Clear();

        if (!selectedRecipeIds.Any())
        {
            errorMessage = "Please select at least one recipe";
            return;
        }

        try
        {
            var request = new GenerateGroceryListRequest(selectedRecipeIds.ToList());
            var result = await RecipeApi.GenerateGroceryListAsync(request);
            groceryList = result.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to generate grocery list: {ex.Message}";
        }
    }

    private void ToggleCheckItem(string itemKey, bool isChecked)
    {
        if (isChecked)
        {
            checkedItems.Add(itemKey);
        }
        else
        {
            checkedItems.Remove(itemKey);
        }
    }

    private void ClearCheckedItems()
    {
        checkedItems.Clear();
    }

    private async Task ExportToExcel()
    {
        if (groceryList == null || !groceryList.Any())
        {
            return;
        }

        try
        {
            var excelData = ExcelExportService.ExportGroceryListToExcel(groceryList);
            var fileName = $"GroceryList_{DateTime.Now:yyyy-MM-dd_HHmmss}.xlsx";
            
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", Convert.ToBase64String(excelData));
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export grocery list: {ex.Message}";
        }
    }

    private async Task ExportToSamsungNotes()
    {
        if (groceryList == null || !groceryList.Any())
        {
            return;
        }

        try
        {
            var textData = TextExportService.ExportGroceryListToSamsungNotes(groceryList);
            var fileName = $"GroceryList_{DateTime.Now:yyyy-MM-dd_HHmmss}.txt";
            
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/plain", Convert.ToBase64String(Encoding.UTF8.GetBytes(textData)));
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export grocery list: {ex.Message}";
        }
    }
}




