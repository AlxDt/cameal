@page "/recipes/edit/{RecipeId:guid}"
@using Cameal.Client.Web.Services
@using Cameal.Client.Web.Models
@inject IRecipeApiClient RecipeApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Recipe</PageTitle>

<h1>Edit Recipe</h1>

@if (recipe == null)
{
    <p><em>Loading recipe...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" @bind="recipeName" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" rows="3" @bind="recipeDescription"></textarea>
            </div>

            <h5 class="mt-4">Ingredients</h5>
            @if (ingredients.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var ingredient in ingredients)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @ingredient.Quantity @ingredient.Unit @ingredient.Name
                            <button class="btn btn-danger btn-sm" @onclick="() => RemoveIngredient(ingredient)">Remove</button>
                        </li>
                    }
                </ul>
            }

            <div class="row g-2 mb-3">
                <div class="col-md-5">
                    <input type="text" class="form-control" placeholder="Ingredient name" @bind="ingredientName" />
                </div>
                <div class="col-md-3">
                    <input type="number" class="form-control" placeholder="Quantity" @bind="ingredientQuantity" step="0.1" />
                </div>
                <div class="col-md-2">
                    <input type="text" class="form-control" placeholder="Unit" @bind="ingredientUnit" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary w-100" @onclick="AddIngredient">Add</button>
                </div>
            </div>

            <h5 class="mt-4">Steps</h5>
            @if (steps.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var step in steps.OrderBy(s => s.Order))
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <strong>Step @step.Order:</strong>
                                    @if (editingStepOrder == step.Order)
                                    {
                                        <textarea class="form-control mt-2" rows="2" @bind="editingStepDescription"></textarea>
                                        <div class="mt-2">
                                            <button class="btn btn-success btn-sm me-2" @onclick="SaveStepEdit">Save</button>
                                            <button class="btn btn-secondary btn-sm" @onclick="CancelStepEdit">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="mb-0 mt-1">@step.Description</p>
                                    }
                                </div>
                                @if (editingStepOrder != step.Order)
                                {
                                    <div class="ms-2">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => MoveStepUp(step)" disabled="@(step.Order == 1)">Up</button>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => MoveStepDown(step)" disabled="@(step.Order == steps.Count)">Down</button>
                                        <button class="btn btn-sm btn-warning me-1" @onclick="() => StartEditStep(step)">Edit</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveStep(step)">Remove</button>
                                    </div>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }

            <div class="row g-2 mb-3">
                <div class="col-md-10">
                    <textarea class="form-control" placeholder="Step description" rows="2" @bind="stepDescription"></textarea>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary w-100" @onclick="AddStep">Add Step</button>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary me-2" @onclick="SaveRecipe">Save Changes</button>
                <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid RecipeId { get; set; }

    private RecipeDto? recipe;
    private string recipeName = string.Empty;
    private string recipeDescription = string.Empty;
    private List<IngredientDto> ingredients = new();
    private List<StepDto> steps = new();
    private string? errorMessage;

    private string ingredientName = string.Empty;
    private double ingredientQuantity;
    private string ingredientUnit = string.Empty;

    private string stepDescription = string.Empty;
    private int? editingStepOrder;
    private string editingStepDescription = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
    }

    private async Task LoadRecipe()
    {
        try
        {
            recipe = await RecipeApi.GetRecipeByIdAsync(RecipeId);
            
            if (recipe == null)
            {
                errorMessage = "Recipe not found";
                return;
            }
            
            recipeName = recipe.Name;
            recipeDescription = recipe.Description;
            ingredients = recipe.Ingredients.ToList();
            steps = recipe.Steps.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load recipe: {ex.Message}";
        }
    }

    private void AddIngredient()
    {
        if (string.IsNullOrWhiteSpace(ingredientName) || 
            ingredientQuantity <= 0 || 
            string.IsNullOrWhiteSpace(ingredientUnit))
        {
            errorMessage = "Please fill in all ingredient fields";
            return;
        }

        ingredients.Add(new IngredientDto(ingredientName, ingredientQuantity, ingredientUnit));
        
        ingredientName = string.Empty;
        ingredientQuantity = 0;
        ingredientUnit = string.Empty;
        errorMessage = null;
    }

    private void RemoveIngredient(IngredientDto ingredient)
    {
        ingredients.Remove(ingredient);
    }

    private void AddStep()
    {
        if (string.IsNullOrWhiteSpace(stepDescription))
        {
            errorMessage = "Please enter a step description";
            return;
        }

        var nextOrder = steps.Any() ? steps.Max(s => s.Order) + 1 : 1;
        steps.Add(new StepDto(nextOrder, stepDescription));
        
        stepDescription = string.Empty;
        errorMessage = null;
    }

    private void RemoveStep(StepDto step)
    {
        steps.Remove(step);
        ReorderSteps();
    }

    private void MoveStepUp(StepDto step)
    {
        if (step.Order == 1)
        {
            return;
        }

        var previousStep = steps.FirstOrDefault(s => s.Order == step.Order - 1);
        if (previousStep != null)
        {
            steps.Remove(step);
            steps.Remove(previousStep);
            steps.Add(new StepDto(step.Order - 1, step.Description));
            steps.Add(new StepDto(previousStep.Order + 1, previousStep.Description));
        }
    }

    private void MoveStepDown(StepDto step)
    {
        if (step.Order == steps.Count)
        {
            return;
        }

        var nextStep = steps.FirstOrDefault(s => s.Order == step.Order + 1);
        if (nextStep != null)
        {
            steps.Remove(step);
            steps.Remove(nextStep);
            steps.Add(new StepDto(step.Order + 1, step.Description));
            steps.Add(new StepDto(nextStep.Order - 1, nextStep.Description));
        }
    }

    private void StartEditStep(StepDto step)
    {
        editingStepOrder = step.Order;
        editingStepDescription = step.Description;
    }

    private void SaveStepEdit()
    {
        if (editingStepOrder.HasValue && !string.IsNullOrWhiteSpace(editingStepDescription))
        {
            var step = steps.FirstOrDefault(s => s.Order == editingStepOrder.Value);
            if (step != null)
            {
                steps.Remove(step);
                steps.Add(new StepDto(editingStepOrder.Value, editingStepDescription));
            }
            CancelStepEdit();
        }
    }

    private void CancelStepEdit()
    {
        editingStepOrder = null;
        editingStepDescription = string.Empty;
    }

    private void ReorderSteps()
    {
        var orderedSteps = steps.OrderBy(s => s.Order).ToList();
        steps.Clear();
        for (int i = 0; i < orderedSteps.Count; i++)
        {
            steps.Add(new StepDto(i + 1, orderedSteps[i].Description));
        }
    }

    private async Task SaveRecipe()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(recipeName) || string.IsNullOrWhiteSpace(recipeDescription))
        {
            errorMessage = "Name and Description are required";
            return;
        }

        try
        {
            var request = new UpdateRecipeRequest(
                recipeName,
                recipeDescription,
                ingredients.Any() ? ingredients : null,
                steps.Any() ? steps : null);

            await RecipeApi.UpdateRecipeAsync(RecipeId, request);
            Navigation.NavigateTo("/recipes");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update recipe: {ex.Message}";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/recipes");
    }
}
