@page "/recipes/edit/{RecipeId:guid}"
@using Cameal.Client.Web.Services
@using Cameal.Client.Web.Models
@inject IRecipeApiClient RecipeApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Recipe</PageTitle>

<h1>Edit Recipe</h1>

@if (recipe == null)
{
    <p><em>Loading recipe...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" @bind="recipeName" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" rows="3" @bind="recipeDescription"></textarea>
            </div>

            <h5 class="mt-4">Ingredients</h5>
            @if (ingredients.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var ingredient in ingredients)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @ingredient.Quantity @ingredient.Unit @ingredient.Name
                            <button class="btn btn-danger btn-sm" @onclick="() => RemoveIngredient(ingredient)">Remove</button>
                        </li>
                    }
                </ul>
            }

            <div class="row g-2 mb-3">
                <div class="col-md-5">
                    <input type="text" class="form-control" placeholder="Ingredient name" @bind="ingredientName" />
                </div>
                <div class="col-md-3">
                    <input type="number" class="form-control" placeholder="Quantity" @bind="ingredientQuantity" step="0.1" />
                </div>
                <div class="col-md-2">
                    <input type="text" class="form-control" placeholder="Unit" @bind="ingredientUnit" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary w-100" @onclick="AddIngredient">Add</button>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary me-2" @onclick="SaveRecipe">Save Changes</button>
                <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid RecipeId { get; set; }

    private RecipeDto? recipe;
    private string recipeName = string.Empty;
    private string recipeDescription = string.Empty;
    private List<IngredientDto> ingredients = new();
    private string? errorMessage;

    private string ingredientName = string.Empty;
    private double ingredientQuantity;
    private string ingredientUnit = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
    }

    private async Task LoadRecipe()
    {
        try
        {
            recipe = await RecipeApi.GetRecipeByIdAsync(RecipeId);
            
            if (recipe == null)
            {
                errorMessage = "Recipe not found";
                return;
            }
            
            recipeName = recipe.Name;
            recipeDescription = recipe.Description;
            ingredients = recipe.Ingredients.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load recipe: {ex.Message}";
        }
    }

    private void AddIngredient()
    {
        if (string.IsNullOrWhiteSpace(ingredientName) || 
            ingredientQuantity <= 0 || 
            string.IsNullOrWhiteSpace(ingredientUnit))
        {
            errorMessage = "Please fill in all ingredient fields";
            return;
        }

        ingredients.Add(new IngredientDto(ingredientName, ingredientQuantity, ingredientUnit));
        
        ingredientName = string.Empty;
        ingredientQuantity = 0;
        ingredientUnit = string.Empty;
        errorMessage = null;
    }

    private void RemoveIngredient(IngredientDto ingredient)
    {
        ingredients.Remove(ingredient);
    }

    private async Task SaveRecipe()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(recipeName) || string.IsNullOrWhiteSpace(recipeDescription))
        {
            errorMessage = "Name and Description are required";
            return;
        }

        try
        {
            var request = new UpdateRecipeRequest(
                recipeName,
                recipeDescription,
                ingredients.Any() ? ingredients : null,
                null);

            await RecipeApi.UpdateRecipeAsync(RecipeId, request);
            Navigation.NavigateTo("/recipes");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update recipe: {ex.Message}";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/recipes");
    }
}
